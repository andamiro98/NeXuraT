{
  "name": "ifc-converter",
  "version": "1.0.0",
  "description": "IFC → .frag 변환 서비스 (That Open Engine 기반)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test:large-open": "node --max-old-space-size=16384 --expose-gc -r ts-node/register src/large-ifc-open-test.ts",
    "test:capacity": "ts-node src/large-ifc-capacity-test.ts"
  },
  "dependencies": {
    "@thatopen/components": "^3.3.3",
    "@thatopen/components-front": "^3.3.3",
    "@thatopen/fragments": "^3.3.7",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "web-ifc": "^0.0.77"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
